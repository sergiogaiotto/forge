# FORGE gateway — copie para gateway/.env e ajuste. NÃO versionar o .env.
PORT=8787

# Provedor upstream in-network (HubGPU). O gateway faz proxy da inferência.
UPSTREAM_BASEURL=https://hub-gpus.claro.com.br/gpt120/v1
# Header de auth do upstream, se necessário (ex.: "Authorization: Bearer xyz").
UPSTREAM_AUTH_HEADER=
UPSTREAM_TIMEOUT_MS=300000

# Sessões e rate limiting
SESSION_TTL_SEC=3600
MAX_SESSIONS=10000
RATE_LIMIT_PER_MIN=120

# TLS opcional (forneça os DOIS para habilitar HTTPS)
HTTPS_KEY=
HTTPS_CERT=

# Verificação de licença: caminho do keyinfo gerado pelo admin (chave pública + key_id)
# e da lista de revogação. Defaults apontam para admin-cli/keys/.
# KEYINFO=../admin-cli/keys/keyinfo.json
# REVOCATIONS=../admin-cli/keys/revocations.json

# --- Observabilidade (Langfuse) — secretKey SERVER-SIDE ONLY (RNF-010) ---------
LANGFUSE_ENABLED=false
LANGFUSE_BASEURL=https://langfuse.interno.claro.com.br
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxx
LANGFUSE_ENV=production
LANGFUSE_SAMPLE_RATE=1.0
# capture: full | masked | metadata-only
LANGFUSE_CAPTURE=masked
