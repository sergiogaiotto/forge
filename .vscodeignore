webview-ui/**
admin-cli/**
gateway/**
ci/**
node_modules/**
.vscode/**
.github/**
.gitlab-ci.yml
**/*.ts
**/*.map
**/tsconfig*.json
esbuild.mjs
vite.config.ts
.gitignore
.gitattributes
.eslintrc*
**/.DS_Store

# Artefatos Python e arquivos de teste gerados no workspace (nunca empacotar)
.venv/**
**/.venv/**
**/__pycache__/**
**/*.py
*.py
cobrinha.py
**/.pytest_cache/**
**/.mypy_cache/**
**/.ruff_cache/**

# Keep the runtime bits: o bundle (dist/extension.js e dist/webview/* entram por padrão),
# o ícone, o catálogo de skills, docs. Os source maps ficam de fora (via **/*.map acima):
# não precisam em runtime e não devem vazar a fonte.
!skills/**
!media/forge-icon.png
!media/flame.svg

# …but never the icon generator or any keys.
media/gen-icon.mjs
**/keys/**
**/*.pem
