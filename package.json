{
  "name": "forge",
  "displayName": "FORGE — Codegen Claro",
  "description": "%ext.description%",
  "version": "2.10.2",
  "publisher": "claro-data-platform",
  "license": "Apache-2.0",
  "icon": "media/forge-icon.png",
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Machine Learning",
    "Data Science",
    "Programming Languages"
  ],
  "keywords": [
    "ai",
    "codegen",
    "data",
    "claro",
    "hubgpu",
    "skills",
    "agent"
  ],
  "galleryBanner": {
    "color": "#181818",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://git.interno.claro.com.br/data-platform/forge"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "%capabilities.untrustedWorkspaces%",
      "restrictedConfigurations": [
        "forge.warehouse.connections",
        "forge.warehouse.default",
        "forge.mcp.catalog",
        "forge.search.server",
        "forge.search.tool",
        "forge.run.commands",
        "forge.test.command",
        "forge.ocr.tesseractPath",
        "forge.gateway.url",
        "forge.rag.embeddings.url",
        "forge.observability.langfuse.baseUrl",
        "forge.egress.allowedHosts",
        "forge.egress.allowExternal",
        "forge.egress.trustInNetwork"
      ]
    }
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "forge-activitybar",
          "title": "FORGE",
          "icon": "media/flame.svg"
        }
      ]
    },
    "views": {
      "forge-activitybar": [
        {
          "type": "webview",
          "id": "forge.sidebar",
          "name": "FORGE",
          "icon": "media/flame.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "forge.focus",
        "title": "%cmd.focus%",
        "category": "FORGE",
        "icon": "$(flame)"
      },
      {
        "command": "forge.openOnRight",
        "title": "%cmd.openOnRight%",
        "category": "FORGE",
        "icon": "$(layout-sidebar-right)"
      },
      {
        "command": "forge.newTask",
        "title": "%cmd.newTask%",
        "category": "FORGE",
        "icon": "$(add)"
      },
      {
        "command": "forge.activateLicense",
        "title": "%cmd.activateLicense%",
        "category": "FORGE"
      },
      {
        "command": "forge.setupProvider",
        "title": "%cmd.setupProvider%",
        "category": "FORGE"
      },
      {
        "command": "forge.reindexSkills",
        "title": "%cmd.reindexSkills%",
        "category": "FORGE",
        "icon": "$(refresh)"
      },
      {
        "command": "forge.reindexCodebase",
        "title": "%cmd.reindexCodebase%",
        "category": "FORGE",
        "icon": "$(database)"
      },
      {
        "command": "forge.runActiveFile",
        "title": "%cmd.runActiveFile%",
        "category": "FORGE",
        "icon": "$(play)"
      },
      {
        "command": "forge.reviewChanges",
        "title": "%cmd.reviewChanges%",
        "category": "FORGE",
        "icon": "$(checklist)"
      },
      {
        "command": "forge.runTests",
        "title": "%cmd.runTests%",
        "category": "FORGE",
        "icon": "$(beaker)"
      },
      {
        "command": "forge.signOut",
        "title": "%cmd.signOut%",
        "category": "FORGE"
      },
      {
        "command": "forge.showOutput",
        "title": "%cmd.showOutput%",
        "category": "FORGE",
        "icon": "$(output)"
      },
      {
        "command": "forge.exportDiagnostics",
        "title": "%cmd.exportDiagnostics%",
        "category": "FORGE",
        "icon": "$(bug)"
      },
      {
        "command": "forge.setupObservability",
        "title": "%cmd.setupObservability%",
        "category": "FORGE"
      },
      {
        "command": "forge.setMaxOutput",
        "title": "%cmd.setMaxOutput%",
        "category": "FORGE",
        "icon": "$(symbol-numeric)"
      },
      {
        "command": "forge.prepareEnv",
        "title": "%cmd.prepareEnv%",
        "category": "FORGE",
        "icon": "$(plug)"
      },
      {
        "command": "forge.pickRole",
        "title": "%cmd.pickRole%",
        "category": "FORGE",
        "icon": "$(person)"
      },
      {
        "command": "forge.inspectIndex",
        "title": "%cmd.inspectIndex%",
        "category": "FORGE",
        "icon": "$(database)"
      },
      {
        "command": "forge.openProfile",
        "title": "%cmd.openProfile%",
        "category": "FORGE",
        "icon": "$(list-tree)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "forge.newTask",
          "when": "view == forge.sidebar",
          "group": "navigation@1"
        },
        {
          "command": "forge.openOnRight",
          "when": "view == forge.sidebar",
          "group": "navigation@5"
        },
        {
          "command": "forge.reindexSkills",
          "when": "view == forge.sidebar",
          "group": "navigation@2"
        },
        {
          "command": "forge.reviewChanges",
          "when": "view == forge.sidebar",
          "group": "navigation@3"
        },
        {
          "command": "forge.reindexCodebase",
          "when": "view == forge.sidebar",
          "group": "navigation@4"
        },
        {
          "command": "forge.showOutput",
          "when": "view == forge.sidebar",
          "group": "navigation@6"
        }
      ]
    },
    "configuration": {
      "title": "FORGE",
      "properties": {
        "forge.gateway.url": {
          "type": "string",
          "default": "",
          "markdownDescription": "%config.gateway.url.md%"
        },
        "forge.license.mode": {
          "type": "string",
          "enum": [
            "gateway",
            "local"
          ],
          "default": "local",
          "markdownDescription": "%config.license.mode.md%"
        },
        "forge.skills.managedDir": {
          "type": "string",
          "default": "",
          "markdownDescription": "%config.skills.managedDir.md%"
        },
        "forge.skills.retrievalThreshold": {
          "type": "number",
          "default": 15,
          "markdownDescription": "%config.skills.retrievalThreshold.md%"
        },
        "forge.skills.topK": {
          "type": "number",
          "default": 8,
          "markdownDescription": "%config.skills.topK.md%"
        },
        "forge.skills.templates": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%config.skills.templates.md%"
        },
        "forge.egress.allowExternal": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "%config.egress.allowExternal.md%"
        },
        "forge.egress.allowedHosts": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "hub-gpus.claro.com.br"
          ],
          "markdownDescription": "%config.egress.allowedHosts.md%"
        },
        "forge.egress.trustInNetwork": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%config.egress.trustInNetwork.md%"
        },
        "forge.mcp.catalog": {
          "type": "array",
          "default": [],
          "markdownDescription": "%config.mcp.catalog.md%",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "transport": {
                "type": "string",
                "enum": [
                  "stdio",
                  "streamableHttp"
                ]
              },
              "command": {
                "type": "string"
              },
              "args": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "url": {
                "type": "string"
              },
              "scope": {
                "type": "string",
                "enum": [
                  "readonly",
                  "readwrite"
                ]
              },
              "autoApprove": {
                "type": "boolean"
              },
              "credentialRef": {
                "type": "string"
              },
              "enabled": {
                "type": "boolean"
              }
            }
          }
        },
        "forge.validation.gateBlocksApply": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%config.validation.gateBlocksApply.md%"
        },
        "forge.gate.definitionOfDone": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%config.gate.definitionOfDone.md%"
        },
        "forge.gate.blockUnverifiedContract": {
          "type": "boolean",
          "default": false,
          "scope": "machine",
          "markdownDescription": "%config.gate.blockUnverifiedContract.md%"
        },
        "forge.gate.security": {
          "type": "string",
          "enum": [
            "conservative",
            "advisory",
            "off"
          ],
          "enumDescriptions": [
            "%config.gate.security.enum.0%",
            "%config.gate.security.enum.1%",
            "%config.gate.security.enum.2%"
          ],
          "default": "conservative",
          "markdownDescription": "%config.gate.security.md%"
        },
        "forge.gate.sql": {
          "type": "string",
          "enum": [
            "conservative",
            "advisory",
            "off"
          ],
          "enumDescriptions": [
            "%config.gate.sql.enum.0%",
            "%config.gate.sql.enum.1%",
            "%config.gate.sql.enum.2%"
          ],
          "default": "conservative",
          "markdownDescription": "%config.gate.sql.md%"
        },
        "forge.gate.deadImports": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%config.gate.deadImports.md%"
        },
        "forge.warehouse.connections": {
          "type": "array",
          "default": [],
          "markdownDescription": "%config.warehouse.connections.md%"
        },
        "forge.warehouse.default": {
          "type": "string",
          "default": "",
          "markdownDescription": "%config.warehouse.default.md%"
        },
        "forge.warehouse.rowCap": {
          "type": "number",
          "default": 50,
          "markdownDescription": "%config.warehouse.rowCap.md%"
        },
        "forge.warehouse.timeoutSeconds": {
          "type": "number",
          "default": 60,
          "markdownDescription": "%config.warehouse.timeoutSeconds.md%"
        },
        "forge.project.reconcileDependencies": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%config.project.reconcileDependencies.md%"
        },
        "forge.rag.enabled": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%config.rag.enabled.md%"
        },
        "forge.rag.embeddings.url": {
          "type": "string",
          "default": "https://hub-gpus.claro.com.br/embed06b/v1",
          "markdownDescription": "%config.rag.embeddings.url.md%"
        },
        "forge.rag.embeddings.model": {
          "type": "string",
          "default": "Qwen/Qwen3-Embedding-0.6B",
          "markdownDescription": "%config.rag.embeddings.model.md%"
        },
        "forge.rag.embeddings.dimensions": {
          "type": "number",
          "default": 0,
          "markdownDescription": "%config.rag.embeddings.dimensions.md%"
        },
        "forge.rag.maxChunks": {
          "type": "number",
          "default": 20,
          "markdownDescription": "%config.rag.maxChunks.md%"
        },
        "forge.rag.maxFileSizeKb": {
          "type": "number",
          "default": 512,
          "markdownDescription": "%config.rag.maxFileSizeKb.md%"
        },
        "forge.rag.include": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/*.py",
            "**/*.ipynb",
            "**/*.sql",
            "**/*.r",
            "**/*.scala",
            "**/*.java",
            "**/*.ts",
            "**/*.js",
            "**/*.md",
            "**/*.yaml",
            "**/*.yml",
            "**/*.toml"
          ],
          "markdownDescription": "%config.rag.include.md%"
        },
        "forge.rag.exclude": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/node_modules/**",
            "**/.git/**",
            "**/dist/**",
            "**/build/**",
            "**/.venv/**",
            "**/venv/**",
            "**/__pycache__/**",
            "**/.ipynb_checkpoints/**",
            "**/target/**",
            "**/.forge/**",
            "**/.env"
          ],
          "markdownDescription": "%config.rag.exclude.md%"
        },
        "forge.telemetry.enabled": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "%config.telemetry.enabled.md%"
        },
        "forge.diagnostics.enabled": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%config.diagnostics.enabled.md%"
        },
        "forge.identity.requireEmail": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "%config.identity.requireEmail.md%"
        },
        "forge.outputLanguage": {
          "type": "string",
          "enum": [
            "auto",
            "pt-BR",
            "en"
          ],
          "enumDescriptions": [
            "%config.outputLanguage.enum.0%",
            "%config.outputLanguage.enum.1%",
            "%config.outputLanguage.enum.2%"
          ],
          "default": "auto",
          "markdownDescription": "%config.outputLanguage.md%"
        },
        "forge.provider.maxOutput": {
          "type": "number",
          "default": 0,
          "markdownDescription": "%config.provider.maxOutput.md%"
        },
        "forge.provider.maxContextWindow": {
          "type": "number",
          "default": 0,
          "markdownDescription": "%config.provider.maxContextWindow.md%"
        },
        "forge.run.enabled": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%config.run.enabled.md%"
        },
        "forge.run.timeoutSeconds": {
          "type": "number",
          "default": 120,
          "markdownDescription": "%config.run.timeoutSeconds.md%"
        },
        "forge.env.timeoutSeconds": {
          "type": "number",
          "default": 900,
          "markdownDescription": "%config.env.timeoutSeconds.md%"
        },
        "forge.run.commands": {
          "type": "object",
          "default": {},
          "markdownDescription": "%config.run.commands.md%"
        },
        "forge.test.enabled": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%config.test.enabled.md%"
        },
        "forge.test.command": {
          "type": "string",
          "default": "pytest -q",
          "markdownDescription": "%config.test.command.md%"
        },
        "forge.test.autoInstall": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "%config.test.autoInstall.md%"
        },
        "forge.search.server": {
          "type": "string",
          "default": "",
          "markdownDescription": "%config.search.server.md%"
        },
        "forge.search.tool": {
          "type": "string",
          "default": "search",
          "markdownDescription": "%config.search.tool.md%"
        },
        "forge.search.queryArg": {
          "type": "string",
          "default": "query",
          "markdownDescription": "%config.search.queryArg.md%"
        },
        "forge.project.managedProfile": {
          "type": "string",
          "default": "",
          "markdownDescription": "%config.project.managedProfile.md%"
        },
        "forge.ocr.tesseractPath": {
          "type": "string",
          "default": "",
          "markdownDescription": "%config.ocr.tesseractPath.md%"
        },
        "forge.ocr.tessdataPath": {
          "type": "string",
          "default": "",
          "markdownDescription": "%config.ocr.tessdataPath.md%"
        },
        "forge.observability.mode": {
          "type": "string",
          "enum": [
            "off",
            "direct",
            "gateway"
          ],
          "enumDescriptions": [
            "%config.observability.mode.enum.0%",
            "%config.observability.mode.enum.1%",
            "%config.observability.mode.enum.2%"
          ],
          "default": "off",
          "markdownDescription": "%config.observability.mode.md%"
        },
        "forge.observability.currency": {
          "type": "string",
          "default": "R$",
          "markdownDescription": "%config.observability.currency.md%"
        },
        "forge.observability.pricing": {
          "type": "object",
          "default": {},
          "markdownDescription": "%config.observability.pricing.md%",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "input": {
                "type": "number"
              },
              "output": {
                "type": "number"
              }
            }
          }
        },
        "forge.observability.langfuse.enabled": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "%config.observability.langfuse.enabled.md%"
        },
        "forge.observability.langfuse.baseUrl": {
          "type": "string",
          "default": "https://cloud.langfuse.com",
          "markdownDescription": "%config.observability.langfuse.baseUrl.md%"
        },
        "forge.observability.langfuse.publicKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "%config.observability.langfuse.publicKey.md%"
        },
        "forge.observability.langfuse.env": {
          "type": "string",
          "default": "development",
          "markdownDescription": "%config.observability.langfuse.env.md%"
        },
        "forge.observability.langfuse.sampleRate": {
          "type": "number",
          "default": 1,
          "markdownDescription": "%config.observability.langfuse.sampleRate.md%"
        },
        "forge.observability.langfuse.capture": {
          "type": "string",
          "enum": [
            "full",
            "masked",
            "metadata-only"
          ],
          "default": "masked",
          "markdownDescription": "%config.observability.langfuse.capture.md%"
        }
      }
    }
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "scripts": {
    "build": "npm run build:webview && npm run build:ext",
    "build:ext": "node esbuild.mjs",
    "build:webview": "vite build",
    "watch:ext": "node esbuild.mjs --watch",
    "watch:webview": "vite build --watch",
    "typecheck": "tsc -p ./tsconfig.json --noEmit && tsc -p ./tsconfig.webview.json --noEmit",
    "test": "tsx --test src/test/*.test.ts",
    "keygen": "node admin-cli/forge-admin.mjs keygen",
    "keygen:build-exe": "node admin-cli/build-exe.mjs",
    "license:issue": "node admin-cli/forge-admin.mjs issue",
    "license:revoke": "node admin-cli/forge-admin.mjs revoke",
    "sign:vsix": "node admin-cli/forge-admin.mjs sign-vsix",
    "verify:vsix": "node admin-cli/forge-admin.mjs verify-vsix",
    "package": "npm run build && vsce package --allow-missing-repository --skip-license --baseContentUrl https://git.interno.claro.com.br/data-platform/forge/-/blob/main --baseImagesUrl https://git.interno.claro.com.br/data-platform/forge/-/raw/main",
    "publish:vsce": "vsce publish",
    "publish:ovsx": "ovsx publish",
    "vscode:prepublish": "npm run build"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/vscode": "^1.93.0",
    "@vitejs/plugin-react": "^4.3.3",
    "@vscode/vsce": "^3.2.1",
    "esbuild": "^0.24.0",
    "ovsx": "^0.10.1",
    "postject": "^1.0.0-alpha.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
